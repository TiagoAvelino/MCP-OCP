FROM registry.access.redhat.com/ubi9/nodejs-22:latest AS build

USER 0
WORKDIR /opt/app-root/src

COPY agent-console/package.json agent-console/package-lock.json ./
RUN npm ci

COPY agent-console/ ./
RUN npm run build

# -----------------------------------------------------------------------------
FROM registry.access.redhat.com/ubi9/nginx-124:latest

USER 0

COPY --chmod=0644 deploy/openshift/nginx.conf /etc/nginx/nginx.conf
COPY --from=build /opt/app-root/src/dist/ /usr/share/nginx/html/

# Prepare writable nginx runtime dirs for arbitrary UID on OpenShift
RUN mkdir -p /var/cache/nginx /var/run/nginx /tmp/nginx && \
    chgrp -R 0 /var/cache/nginx /var/run/nginx /tmp/nginx /usr/share/nginx/html /etc/nginx && \
    chmod -R g=u /var/cache/nginx /var/run/nginx /tmp/nginx /usr/share/nginx/html /etc/nginx

EXPOSE 8080

CMD ["nginx", "-g", "daemon off;"]