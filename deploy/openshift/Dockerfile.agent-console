# Build from repository root:
#   podman build -f deploy/openshift/Dockerfile.agent-console -t agent-console:latest .
#
FROM docker.io/node:22-alpine AS build
WORKDIR /src
COPY agent-console/package.json agent-console/package-lock.json* ./
RUN npm ci
COPY agent-console/ ./
RUN npm run build

FROM docker.io/nginx:1.26-alpine

COPY deploy/openshift/nginx.conf /etc/nginx/nginx.conf

RUN chgrp -R 0 /etc/nginx/nginx.conf /var/cache/nginx /var/run /var/log/nginx /usr/share/nginx/html && \
    chmod -R g=u /etc/nginx/nginx.conf /var/cache/nginx /var/run /var/log/nginx /usr/share/nginx/html && \
    touch /var/run/nginx.pid && chgrp 0 /var/run/nginx.pid && chmod g=u /var/run/nginx.pid

COPY --from=build /src/dist /usr/share/nginx/html

USER 101

EXPOSE 8080

CMD ["nginx", "-g", "daemon off;"]
